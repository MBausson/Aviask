@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="navb-list">
    @if (SignInManager.IsSignedIn(User))
    {

        @if (User.IsInRole("admin"))
        {
            <span class="text-danger nav-link">Admin</span>
        }
        else
        {
            <span class="text-info nav-link">Not admin</span>
        }

        <a id="manage" class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Logged in as @UserManager.GetUserName(User)!</a>

        <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0">
                <i class="fa-sharp fa-solid fa-arrow-right-from-bracket"></i>
                Logout
            </button>
        </form>
    }
    else
    {
        <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    }
</div>
