@using Microsoft.AspNetCore.Identity;
@model UserViewModel

@{
    ViewData["Title"] = $"Delete user";
}

<h1 class="text-4xl font-semibold my-4">Delete user</h1>
<h3 class="text-2xl font-medium">Are you sure you want to delete this user ?</h3>

<hr class="border-[#c7c8c9] border-t border-b my-3" />

<div>
    <section class="flex flex-col gap-2 mb-4">
        <div>
            <span class="text-xl underline font-medium">@Html.DisplayNameFor(model => model.User.Id)</span> : 
            <span class="text-lg cursor-pointer">@Html.DisplayFor(model => model.User.Id)</span>
        </div>

        <div>
            <span class="text-xl underline font-medium">@Html.DisplayNameFor(model => model.User.UserName)</span> :
            <span class="text-lg cursor-pointer">@Html.DisplayFor(model => model.User.UserName)</span>
        </div>

        <div>
            <span class="text-xl underline font-medium">@Html.DisplayNameFor(model => model.User.Email)</span> : 
            <span class="text-lg cursor-pointer">@Html.DisplayFor(model => model.User.Email)</span>
        </div>

        <div>
            <span class="text-xl underline font-medium">@Html.DisplayNameFor(model => model.Roles)</span> : 
            <span class="inline-flex gap-2">
                @foreach (var role in Model.Roles)
                {
                    <span class="text-lg cursor-pointer">@role</span>
                }
            </span>
        </div>
    </section>
    @*<dl>
        <dt>
            @Html.DisplayNameFor(model => model.User.Id)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.Id)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.User.Email)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.User.Email)
        </dd>

        <dt>
            Roles
        </dt>
        <dd>
            <ul>
                @foreach (var role in Model.Roles)
                {
                    <li><u>@role</u></li>
                }
            </ul>
        </dd>
    </dl>*@

    <form asp-action="Delete" asp-route-userid="@Model.User.Id" method="post">
        <a class="button button-primary" asp-action="Index">Back to list</a>
        <button class="button button-important">
            <i class="fa fa-trash"></i>
            Confirm delete
        </button>
    </form>
</div>