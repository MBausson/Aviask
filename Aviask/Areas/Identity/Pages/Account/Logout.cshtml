@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<header class="my-4">
    <h1 class="text-4xl font-semibold mb-4">Log out from Aviask</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button class="button button-important">Click here to Logout</button>
            </form>
        }
        else
        {
            <p class="text-4xl font-semibold">You have successfully logged out of the application.</p>
        }
    }
</header>
